<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      The loopback server needs INTERNET to open a 127.0.0.1 socket. The `linked`
      flavor inherits this from the agent AAR's manifest; the `noagent` flavor must
      declare it itself so an INJECTED server can bind. Real-world targets (e.g.
      easypln) already hold INTERNET — this keeps the test target honest.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Reticle Sample"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        <activity
            android:name="dev.reticle.sample.MainActivity"
            android:label="Reticle Sample"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="dev.reticle.sample.CheckoutScenarioActivity"
            android:exported="false"
            android:label="Checkout Controls" />
        <activity
            android:name="dev.reticle.sample.AgreementScenarioActivity"
            android:exported="false"
            android:label="Agreement Regions" />
        <activity
            android:name="dev.reticle.sample.WebViewScenarioActivity"
            android:exported="false"
            android:label="WebView DOM"
            android:theme="@style/Theme.AppCompat.Light.DarkActionBar" />
        <activity
            android:name="dev.reticle.sample.LoginScenarioActivity"
            android:exported="false"
            android:label="Login Keyboard Trap" />
    </application>
</manifest>
