<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Loopback server only needs INTERNET to open a localhost socket. It binds
      to 127.0.0.1 and is reached by the host CLI through `adb forward`, exactly
      like Loupe's localhost-only LoupeServer.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <!--
          Auto-start hook. Mirrors Loupe's __attribute__((constructor)) +
          dlsym("LoupeInjectorStart"): a content provider is instantiated very
          early in process startup (before Application.onCreate returns control
          to UI), so the host app does not need to call any Reticle code. This
          is the same trick androidx App Startup / Firebase use to self-init.
        -->
        <provider
            android:name="dev.reticle.agent.ReticleInitProvider"
            android:authorities="${applicationId}.reticle-init"
            android:exported="false"
            android:initOrder="100" />
    </application>
</manifest>
